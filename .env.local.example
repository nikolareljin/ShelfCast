# ShelfCast Development Environment Configuration
# Copy to .env.local and customize for your setup
# This file is used by deployment scripts on your Ubuntu dev machine

# Raspberry Pi SSH Connection
SHELFCAST_PI_HOST=192.168.1.100   # Pi IP address or hostname
SHELFCAST_PI_USER=pi              # Pi username
SHELFCAST_PI_PATH=/home/pi/ShelfCast  # Install path on Pi

# SSH Key (optional - uses default if not set)
# SHELFCAST_SSH_KEY=~/.ssh/id_ed25519
