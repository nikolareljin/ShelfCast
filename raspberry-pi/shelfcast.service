[Unit]
Description=ShelfCast Dashboard Server
After=network.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/ShelfCast/web-app
Environment="PATH=/home/pi/ShelfCast/web-app/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/pi/ShelfCast/web-app/.venv/bin/python app.py
Restart=always
RestartSec=5

# Logging
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
