# udev rules for Nook Simple Touch ADB access
# Copy to /etc/udev/rules.d/51-nook.rules

# Nook Simple Touch (Barnes & Noble)
SUBSYSTEM=="usb", ATTR{idVendor}=="2080", MODE="0666", GROUP="plugdev"

# Nook in ADB mode
SUBSYSTEM=="usb", ATTR{idVendor}=="2080", ATTR{idProduct}=="0002", MODE="0666", GROUP="plugdev", SYMLINK+="nook"

# Nook in recovery mode
SUBSYSTEM=="usb", ATTR{idVendor}=="2080", ATTR{idProduct}=="0003", MODE="0666", GROUP="plugdev"

# Generic Android fallback
SUBSYSTEM=="usb", ATTR{idVendor}=="18d1", MODE="0666", GROUP="plugdev"
